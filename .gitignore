conll2003/
data/
*.txt
*.csv
*.tsv
*.json

# =====================================================================
# PYTHON ENVIRONMENT & CACHE
# =====================================================================
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.rasterio/

# Virtual Environments
venv/
.venv/
env/
ENV/
dist/
build/
*.egg-info/

# =====================================================================
# PYTORCH MODEL WEIGHTS & CHECKPOINTS
# =====================================================================
